fonts/adobe-clean/
fonts/gill-sans-nova/
fonts/minion-pro/
fonts/myriad-pro/

# Local citation PDFs (gitignored; citeurls.tex falls back to public URLs)
books/short-reach-optics/docs/*
!books/short-reach-optics/docs/README.md

# Cursor hook runtime files
.cursor/hooks/.tex-compile.stamp
